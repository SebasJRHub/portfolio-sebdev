    </a>

    <button id="menu-btn" class="md:hidden text-white z-50">
      <svg id="icon-menu" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

    <nav id="nav-menu" class="hidden md:flex gap-8">
      <a href="#inicio" class="font-mono text-xs tracking-widest text-gray-400 hover:text-[#7c6fff] transition-colors group relative py-2">
        01 inicio
        <span class="absolute bottom-0 left-0 h-0.5 w-full origin-left scale-x-0 transform bg-[#7c6fff] transition-transform duration-500 ease-out group-hover:scale-x-100"></span>
      </a>
      <a href="#sobre-mi" class="font-mono text-xs tracking-widest text-gray-400 hover:text-[#7c6fff] transition-colors group relative py-2">
        02 sobre mi
        <span class="absolute bottom-0 left-0 h-0.5 w-full origin-left scale-x-0 transform bg-[#7c6fff] transition-transform duration-500 ease-out group-hover:scale-x-100"></span>
      </a>
      <a href="#skills" class="font-mono text-xs tracking-widest text-gray-400 hover:text-white transition-colors group relative py-2">
        03 skills
        <span class="absolute bottom-0 left-0 h-0.5 w-full origin-left scale-x-0 transform bg-[#7c6fff] transition-transform duration-500 ease-out group-hover:scale-x-100"></span>
      </a>
      <a href="#proyectos" class="font-mono text-xs tracking-widest text-gray-400 hover:text-white transition-colors group relative py-2">
        04 proyectos
        <span class="absolute bottom-0 left-0 h-0.5 w-full origin-left scale-x-0 transform bg-[#7c6fff] transition-transform duration-500 ease-out group-hover:scale-x-100"></span>
      </a>
      <a href="#formacion" class="font-mono text-xs tracking-widest text-gray-400 hover:text-white transition-colors group relative py-2">
        05 educación
        <span class="absolute bottom-0 left-0 h-0.5 w-full origin-left scale-x-0 transform bg-[#7c6fff] transition-transform duration-500 ease-out group-hover:scale-x-100"></span>
