      <a href="#contacto" class="font-mono text-xs tracking-widest text-gray-400 hover:text-white transition-colors group relative py-2">
        06 contacto
        <span class="absolute bottom-0 left-0 h-0.5 w-full origin-left scale-x-0 transform bg-[#7c6fff] transition-transform duration-500 ease-out group-hover:scale-x-100"></span>
      </a>
    </nav>
</header>

<!-- menu mobile fullscreen, AHORA FUERA del header -->
<div id="mobile-menu" class="hidden fixed inset-0 bg-[#0a0a0f] flex flex-col items-center justify-center gap-8 z-40">
  <a href="#inicio" class="mobile-link font-mono text-sm tracking-widest text-gray-400">01 inicio</a>
  <a href="#sobre-mi" class="mobile-link font-mono text-sm tracking-widest text-gray-400">02 sobre mi</a>
  <a href="#skills" class="mobile-link font-mono text-sm tracking-widest text-gray-400">03 skills</a>
  <a href="#proyectos" class="mobile-link font-mono text-sm tracking-widest text-gray-400">04 proyectos</a>
  <a href="#formacion" class="mobile-link font-mono text-sm tracking-widest text-gray-400">05 educación</a>
  <a href="#contacto" class="mobile-link font-mono text-sm tracking-widest text-gray-400">06 contacto</a>
</div>

<script>
  const header = document.getElementById('header');
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  window.addEventListener('scroll', () => {
    if (header) {
      if (window.scrollY > 50) {
        header.classList.add('bg-[#0a0a0f]/80', 'backdrop-blur-md', 'border-b', 'border-[#7c6fff]/30');
      } else {
        header.classList.remove('bg-[#0a0a0f]/80', 'backdrop-blur-md', 'border-b', 'border-[#7c6fff]/30');
      }
    }
  });

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  mobileLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();

      const targetId = link.getAttribute('href');
      if (!targetId) return;

      const targetEl = document.querySelector(targetId);

      mobileMenu?.classList.add('hidden');

      setTimeout(() => {
        targetEl?.scrollIntoView({ behavior: 'smooth' });
      }, 100);
    });
  });
</script>